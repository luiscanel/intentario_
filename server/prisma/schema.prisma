generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Módulos del sistema (agregables bajo demanda)
model Modulo {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  descripcion String?
  icono       String?      // Icono para el menú
  orden       Int          @default(0)
  activo      Boolean      @default(true)
  permisos    Permiso[]
  roles       RolModulo[]
  createdAt   DateTime     @default(now())
}

// Roles del sistema (admin, viewer, o personalizados)
model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  descripcion String?
  esBase      Boolean      @default(false) // true para admin y viewer
  roles       RolModulo[]  // Relación muchos a muchos con módulos
  permisos    Permiso[]    // Permisos asignados al rol
  usuarios    UsuarioRol[]
  createdAt   DateTime     @default(now())
}

// Relación muchos a muchos Rol-Modulo (qué módulos tiene cada rol)
model RolModulo {
  rolId    Int
  moduloId Int
  rol      Rol    @relation(fields: [rolId], references: [id], onDelete: Cascade)
  modulo   Modulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@id([rolId, moduloId])
}

// Permisos por módulo (ver, crear, editar, eliminar, exportar)
model Permiso {
  id       Int     @id @default(autoincrement())
  moduloId Int
  accion   String  // ver, crear, editar, eliminar, exportar
  modulo   Modulo  @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  rol      Rol?    @relation(fields: [rolId], references: [id], onDelete: Cascade)
  rolId    Int?

  //@@unique([moduloId, accion]) // Comentado para permitir múltiples permisos de rol
}

// Relación muchos a muchos usuarios-roles
model UsuarioRol {
  usuarioId Int
  rolId     Int
  usuario   User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol  @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
}

model User {
  id                Int           @id @default(autoincrement())
  email             String        @unique
  password          String
  nombre            String
  rol               String        @default("user")
  activo            Boolean       @default(true)
  debeCambiarPass   Boolean       @default(false)  // Forzar cambio de contraseña
  passwordChangedAt DateTime?     // Última vez que cambió la contraseña
  // Seguridad: Control de intentos de login
  intentosLogin     Int           @default(0)       // Contador de intentos fallidos
  bloqueadoHasta    DateTime?     // Cuándo se desbloqueará la cuenta
  ultimoIntento     DateTime?     // Último intento de login
  ultimoAccesoActivo DateTime?    // Último acceso activo (para timeout por inactividad)
  usuarioRoles      UsuarioRol[]
  sesiones          Sesion[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Servidor {
  id               Int      @id @default(autoincrement())
  pais             String?
  host             String?
  nombreVM         String?
  ip               String?
  tipo             String?
  cpu              Int?
  memoria          String?
  disco            String?
  ambiente         String?
  arquitectura     String?
  sistemaOperativo String?
  version          String?
  antivirus        String?
  estado           String?
  responsable      String?
  fechaGarantia    DateTime?
  documentos       Documento[]
  certificadosSSL  CertificadoSSL[]
  licencias        Licencia[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InventarioFisico {
  id             Int      @id @default(autoincrement())
  pais           String
  categoria      String
  marca          String
  modelo         String?
  serie          String?
  inventario     String?
  estado         String
  responsable    String?
  observaciones  String?
  equipo         String?
  direccionIp    String?
  ilo            String?
  descripcion    String?
  serial         String?
  sistemaOperativo String?
  garantia       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model InventarioCloud {
  id               Int     @id @default(autoincrement())
  tenant           String?
  nube             String?
  instanceName     String?
  ipPublica        String?
  ipPrivada        String?
  instanceType     String?
  cpu              Int?
  ram              String?
  storageGib       String?
  sistemaOperativo String?
  costoUsd         String?
  hostName         String?
  responsable      String?
  modoUso          String?
  service          String?
  antivirus        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  clave     String   @unique
  valor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailConfig {
  id          Int      @id @default(autoincrement())
  host        String
  puerto      Int      @default(587)
  usuario     String
  contrasena  String
  usandoTls   Boolean  @default(true)
  emailFrom   String
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// AUDIT LOG - Historial de cambios
// ============================================
model AuditLog {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?
  usuario     String?  // Nombre o email del usuario
  accion      String   // login, create, update, delete, export, import
  entidad     String   // User, Servidor, InventarioFisico, etc.
  entidadId   Int?     // ID del registro afectado
  datosPrevios String? // JSON con datos anteriores
  datosNuevos String?  // JSON con datos nuevos
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// ============================================
// PROVEEDORES
// ============================================
model Proveedor {
  id          Int        @id @default(autoincrement())
  nombre      String
  contacto    String?
  email       String?
  telefono    String?
  direccion   String?
  servicios   String?    // Servicios que provee (separados por coma)
  notas       String?
  activo      Boolean    @default(true)
  contratos   Contrato[]
  licencias   Licencia[]
  certificadosSSL CertificadoSSL[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ============================================
// CONTRATOS Y GARANTÍAS
// ============================================
model Contrato {
  id            Int       @id @default(autoincrement())
  proveedorId   Int?
  proveedor     Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  tipo          String?   // Mantenimiento, Soporte, Hosting, Garantía, Otro
  numero        String?   // Número de contrato
  objeto        String?   // Descripción del contrato
  monto         Float?
  moneda        String    @default("USD")
  fechaInicio   DateTime?
  fechaFin      DateTime?
  estado        String    @default("Activo") // Activo, Vencido, Renovado, Cancelado
  observaciones String?
  diasAviso     Int       @default(30) // Días de aviso antes de vencer
  documentos    Documento[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// DOCUMENTOS
// ============================================
model Documento {
  id          Int       @id @default(autoincrement())
  nombre      String
  tipo        String    // contrato, licencia, factura, otro
  url         String
  mimeType    String?
  tamano      Int?      // bytes
  contratoId  Int?
  contrato    Contrato? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  licenciaId  Int?
  licencia    Licencia? @relation(fields: [licenciaId], references: [id], onDelete: Cascade)
  servidorId  Int?
  servidor    Servidor? @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// ============================================
// LICENCIAS DE SOFTWARE
// ============================================
model Licencia {
  id            Int       @id @default(autoincrement())
  nombre        String
  tipo          String    // Windows, Office, Antivirus, SQL, Otro
  version       String?
  cantidad      Int       @default(1)
  usada         Int       @default(0)
  costo         Float?
  moneda        String    @default("USD")
  fechaCompra   DateTime?
  fechaVencimiento DateTime?
  proveedorId   Int?
  proveedor     Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  servidorId    Int?      // Servidor donde está instalada (opcional)
  servidor      Servidor? @relation(fields: [servidorId], references: [id], onDelete: SetNull)
  notas         String?
  activa        Boolean   @default(true)
  documentos    Documento[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// MONITOR DE DISPONIBILIDAD
// ============================================
model Disponibilidad {
  id          Int       @id @default(autoincrement())
  servidorId  Int?      // Relación opcional con servidor
  ip          String
  nombre      String?   // Nombre del host
  tipo        String?   // http, https, tcp, ssh, mysql, postgres, redis, ping, dns
  puerto      Int?      // Puerto a verificar
  status      String    @default("unknown") // online, offline, unknown
  latency     Int?      // Latencia en ms
  ultimoCheck DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

model HistorialDisponibilidad {
  id          Int       @id @default(autoincrement())
  ip          String
  status      String    // online, offline
  latency     Int?
  checkTime   DateTime  @default(now())
}

// ============================================
// ALERTAS
// ============================================
model Alerta {
  id          Int       @id @default(autoincrement())
  tipo        String    // info, warning, error, critical
  titulo      String
  mensaje     String
  entidad     String?   // Servidor, Contrato, Licencia, etc.
  entidadId   Int?
  leida       Boolean   @default(false)
  leidaPor    String?
  leidaAt     DateTime?
  createdAt   DateTime  @default(now())
}

// ============================================
// CERTIFICADOS SSL
// ============================================
model CertificadoSSL {
  id            Int       @id @default(autoincrement())
  dominio       String
  tipo          String    // wildcard, single, SAN
  emisor        String?   // Let's Encrypt, DigiCert, etc.
  fechaEmision  DateTime?
  fechaVencimiento DateTime
  proveedorId   Int?
  proveedor     Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  servidorId    Int?
  servidor      Servidor?  @relation(fields: [servidorId], references: [id], onDelete: SetNull)
  notas         String?
  alertasEnviadas Int     @default(0)  // Cantidad de alertas enviadas
  ultimoCheck   DateTime  @default(now())
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// GESTIÓN DE CAMBIOS
// ============================================
model Cambio {
  id            Int       @id @default(autoincrement())
  titulo        String
  descripcion   String
  tipo          String    // emergencia, normal, preventivo
  prioridad     String    // baja, media, alta, critica
  estado        String    @default("pendiente") // pendiente, aprobado, rechazado, en_progreso, completado, cancelado
  
  // Solicitud
  solicitanteId Int?
  solicitante   String?   // Email del solicitante
  
  // Aprobación
  aprobadorId   Int?
  aprobador     String?   // Email del aprobador
  fechaAprobacion DateTime?
  comentariosAprobacion String?
  
  // Ejecución
  fechaInicio   DateTime?
  fechaFin      DateTime?
  responsableEjecucion String?
  
  // Rollback
  planRollback  String?
  rollbackRealizado Boolean @default(false)
  
  // Impacto
  serviciosAfectados String?  // JSON array de servicios
  downtimeEstimado String?     // ej: "30 minutos"
  downtimeReal    String?
  
  notas          String?
  logs          CambioLog[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CambioLog {
  id          Int       @id @default(autoincrement())
  cambioId    Int
  cambio      Cambio    @relation(fields: [cambioId], references: [id], onDelete: Cascade)
  usuario     String?
  accion      String    // created, updated, approved, rejected, started, completed, cancelled
  detalles    String?   // JSON con detalles del cambio
  createdAt   DateTime  @default(now())
}

// ============================================
// BACKUPS PROGRAMADOS
// ============================================
model BackupProgramado {
  id            Int       @id @default(autoincrement())
  nombre        String
  tipo          String    // completo, incremental
  frecuencia    String    // daily, weekly, monthly
  diaSemana     Int?      // 0-6 (0=domingo) para weekly
  diaMes        Int?      // 1-31 para monthly
  hora          Int       // 0-23
  minuto        Int       // 0-59
  retenerDias   Int       @default(30)  // Cuántos días mantener
  
  activo        Boolean   @default(true)
  ultimoBackup  DateTime?
  proximoBackup DateTime?
  ultimoEstado  String?   // success, failed
  ultimoMensaje String?
  
  notificaciones Boolean  @default(true)  // Enviar email al finalizar
  emailNotificacion String?
  
  historiales   HistorialBackup[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model HistorialBackup {
  id            Int       @id @default(autoincrement())
  backupId     Int
  backup       BackupProgramado @relation(fields: [backupId], references: [id], onDelete: Cascade)
  inicio        DateTime
  fin           DateTime?
  estado        String    // running, success, failed
  tamanoBytes  Int?
  mensaje       String?
  archivo       String?   // Nombre del archivo de backup
  createdAt    DateTime  @default(now())
}

// ============================================
// SESIONES DE USUARIOS
// ============================================
model Sesion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token         String    @unique
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  ultimoAcceso  DateTime  @default(now())
  activa        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

// ============================================
// COSTOS CLOUD
// ============================================
model CostoCloud {
  id            Int       @id @default(autoincrement())
  proveedor     String    // AWS, Azure, GCP
  cuenta        String    // Account ID o nombre
  servicio      String    // EC2, S3, RDS, etc.
  region        String?
  mes           String    // YYYY-MM
  moneda        String    @default("USD")
  monto         Float
  etiquetas     String?   // JSON con tags
  
  createdAt     DateTime  @default(now())
  
  @@unique([proveedor, cuenta, servicio, region, mes])
}

// ============================================
// CONFIGURACIÓN DE ALERTAS
// ============================================
model ConfigAlerta {
  id                Int       @id @default(autoincrement())
  tipo              String    // "servidor_caido", "contrato_vencer", "licencia_vencer", "certificado_vencer", "garantia_vencer"
  nombre            String
  diasAntelacion    Int       @default(30)  // Días de anticipación
  diasVerificacion  Int       @default(30)  // Cada cuántos días verificar
  activo            Boolean   @default(true)
  enviarEmail       Boolean   @default(true)
  crearAlerta       Boolean   @default(true)
  emailDestino      String?   // Email adicional para notificaciones
  
  creadoPor         Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tipo])
}
